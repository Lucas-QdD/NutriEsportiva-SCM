generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum PapelUsuario {
  ATLETA
  TECNICO
  NUTRICIONISTA
}

enum StatusHidratacao {
  BOA
  MODERADA
  RUIM
}

model Usuario {
  id             String          @id @default(cuid())
  nome           String
  email          String          @unique
  senha          String
  papel          PapelUsuario
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt

  equipeId       String?
  equipe         Equipe?         @relation(fields: [equipeId], references: [id])

  perfilAtleta   PerfilAtleta?
}

model Equipe {
  id        String           @id @default(cuid())
  nome      String
  codigo    String           @unique
  criadoEm  DateTime         @default(now())
  atualizadoEm DateTime      @updatedAt

  usuarios  Usuario[]
  atletas   PerfilAtleta[]
}

model PerfilAtleta {
  id           String            @id @default(cuid())
  usuarioId    String            @unique
  equipeId     String
  codigoAtleta String            @unique
  idade        Int
  esporte      String?
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  usuario      Usuario           @relation(fields: [usuarioId], references: [id])
  equipe       Equipe            @relation(fields: [equipeId], references: [id])
  sessoes      SessaoTreino[]
}

model SessaoTreino {
  id                String           @id @default(cuid())
  atletaId          String
  dataSessao        DateTime
  duracaoMin        Int
  metodoMedicao     String
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt

  atleta            PerfilAtleta     @relation(fields: [atletaId], references: [id])
  registro          RegistroHidratacao?
  resultado         ResultadoHidratacao?
}

model RegistroHidratacao {
  id                String           @id @default(cuid())
  sessaoId          String           @unique
  pesoPreKg         Float
  pesoPosKg         Float
  liquidoIngeridoL  Float            @default(0)
  volumeUrinaL      Float?
  temperaturaC      Float?
  umidadePercent    Float?
  sintomas          String?
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt

  sessao            SessaoTreino     @relation(fields: [sessaoId], references: [id])
}

model ResultadoHidratacao {
  id                  String           @id @default(cuid())
  sessaoId            String           @unique
  taxaSuorLPorHora    Float
  statusHidratacao    StatusHidratacao
  recomendacao        String
  criadoEm            DateTime         @default(now())
  atualizadoEm        DateTime         @updatedAt

  sessao              SessaoTreino     @relation(fields: [sessaoId], references: [id])
}